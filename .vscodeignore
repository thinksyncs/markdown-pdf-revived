.vscode/**
.github/**
.gitignore
.DS_Store
.playwright-mcp/**
original-icon.png
test/**
test-docs/**
docs/**
src/**
dist/*.map
esbuild.js
tsconfig.json
work/**
*.vsix
*.vsix.zip
*.bat

# Exclude all of node_modules — pure-JS deps are bundled into dist/extension.js
node_modules/**

# Re-include only file assets that the extension reads from disk at runtime.
# All JS dependencies (including puppeteer-core, jsdom, dompurify, and their
# transitive deps) are bundled into dist/extension.js by esbuild.

# mermaid: only the pre-built browser bundle (inlined into HTML at render time)
!node_modules/mermaid/dist/mermaid.min.js

# katex: CSS and fonts (linked via file:// so font paths resolve in Puppeteer)
!node_modules/katex/dist/katex.min.css
!node_modules/katex/dist/fonts/**

# highlight.js: CSS theme files (linked via file://)
!node_modules/highlight.js/styles/**

# emoji-images: PNG image files (loaded by path at runtime)
!node_modules/emoji-images/pngs/**
